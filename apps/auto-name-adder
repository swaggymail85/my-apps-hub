<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Multi-Genre Track Renamer</title>
    <style>
        body { font-family: system-ui, sans-serif; background: #121212; color: #fff; display: flex; justify-content: center; align-items: center; min-height: 100vh; margin: 0; padding: 20px; box-sizing: border-box; }
        .card { background: #1e1e1e; padding: 30px; border-radius: 12px; text-align: center; max-width: 460px; width: 100%; box-shadow: 0 8px 24px rgba(0,0,0,0.5); }
        
        /* Genre Selector Styles */
        .genre-container { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; margin: 20px 0; }
        .genre-btn { background: #2a2a2a; color: #aaa; border: 2px solid transparent; padding: 10px; border-radius: 8px; cursor: pointer; font-weight: 600; font-size: 13px; transition: 0.2s; }
        .genre-btn:hover { background: #333; color: #fff; }
        .genre-btn.active { border-color: #673ab7; background: #24143e; color: #e1bee7; }
        
        input[type="file"] { margin: 20px 0 10px 0; width: 100%; color: #ccc; }
        
        /* Checkbox Styling */
        .option-container { display: flex; align-items: center; justify-content: center; gap: 8px; margin-bottom: 20px; font-size: 14px; color: #ccc; cursor: pointer; user-select: none; }
        .option-container input { cursor: pointer; accent-color: #673ab7; width: 16px; height: 16px; }

        button.action-btn { color: white; border: none; padding: 12px 24px; font-size: 16px; border-radius: 6px; cursor: pointer; font-weight: bold; width: 100%; transition: 0.2s; margin-bottom: 10px; }
        .btn-primary { background: #673ab7; }
        .btn-primary:hover { background: #512da8; }
        .btn-success { background: #2e7d32; display: none; }
        .btn-success:hover { background: #1b5e20; }
        button:disabled { background: #444; color: #888; cursor: not-allowed; }
        #status { margin: 15px 0; color: #b39ddb; font-size: 14px; font-weight: 500; }
        .reset-link { color: #aaa; text-decoration: underline; cursor: pointer; font-size: 13px; display: none; }
    </style>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
</head>
<body>

<div class="card">
    <h2>Multi-Genre Playlist Renamer</h2>
    <p style="color: #aaa; font-size: 14px; margin-bottom: 5px;">Select your aesthetic pool, drop your tracks, and automatically generate non-repeating layouts.</p>
    
    <div class="genre-container">
        <button class="genre-btn active" onclick="setGenre('dnb')">🔊 DnB & Jungle</button>
        <button class="genre-btn" onclick="setGenre('lofi')">☕ Cozy Lofi</button>
        <button class="genre-btn" onclick="setGenre('vaporwave')">🌴 Vaporwave 1995</button>
        <button class="genre-btn" onclick="setGenre('ambient')">🌧️ Deep Ambient</button>
    </div>
    
    <input type="file" id="fileInput" accept=".mp3" multiple>
    
    <label class="option-container">
        <input type="checkbox" id="keepOldNameCheckbox" checked>
        Keep original filename in brackets
    </label>
    
    <button id="processBtn" class="action-btn btn-primary" disabled>Rename & Process</button>
    <button id="downloadBtn" class="action-btn btn-success">Download ZIP</button>
    
    <div id="status"></div>
    <span id="resetLink" class="reset-link">Clear and restart</span>
</div>

