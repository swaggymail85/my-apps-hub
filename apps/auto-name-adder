        ],
        ambient: [
            'bleak', 'cold', 'dark', 'dim', 'faded', 'faint', 'gloom', 'gray', 'grey', 'grim',
            'pale', 'shadow', 'somber', 'weary', 'worn', 'bitter', 'frozen', 'ice', 'icy', 'chill',
