            'eon', 'eternity', 'dust', 'dusty', 'ash', 'ashy', 'soot', 'cinder', 'ember', 'dying_ember'
        ]
    };

    let selectedGenre = 'dnb';
    let generatedZipBlob = null;

    const fileInput = document.getElementById('fileInput');
    const keepOldNameCheckbox = document.getElementById('keepOldNameCheckbox');
    const processBtn = document.getElementById('processBtn');
    const downloadBtn = document.getElementById('downloadBtn');
    const statusDiv = document.getElementById('status');
    const resetLink = document.getElementById('resetLink');

    function setGenre(genre) {
        if(fileInput.disabled) return; // Prevent changing genre mid-process
        selectedGenre = genre;
        document.querySelectorAll('.genre-btn').forEach(btn => btn.classList.remove('active'));
        event.target.classList.add('active');
    }

    fileInput.addEventListener('change', () => {
        processBtn.disabled = fileInput.files.length === 0;
        statusDiv.innerText = `${fileInput.files.length} file(s) selected.`;
    });

    function capitalize(word) {
        if (!word) return '';
        return word.charAt(0).toUpperCase() + word.slice(1).toLowerCase();
    }

    processBtn.addEventListener('click', async () => {
        const files = fileInput.files;
        if (files.length === 0) return;

        const keepOriginalName = keepOldNameCheckbox.checked;

        processBtn.disabled = true;
        fileInput.disabled = true;
        keepOldNameCheckbox.disabled = true;
        statusDiv.innerText = `Processing unique ${selectedGenre.toUpperCase()} titles...`;

        const zip = new JSZip();
        let availableWords = [...genrePools[selectedGenre]];
        const usedFullNames = new Set();

        let structures = [];
        for (let s = 0; s < files.length; s++) {
            structures.push(s % 3); 
        }
        
        for (let s = structures.length - 1; s > 0; s--) {
            const j = Math.floor(Math.random() * (s + 1));
            [structures[s], structures[j]] = [structures[j], structures[s]];
        }

        for (let i = 0; i < files.length; i++) {
            const file = files[i];
            let trackWords = [];
            const chosenStructure = structures[i]; 

            // Fallback safety valve if selected pool runs short of random pulls
            if (availableWords.length < 5) {
                availableWords = [...genrePools[selectedGenre]];
            }

            const pullWord = () => {
                const index = Math.floor(Math.random() * availableWords.length);
                return availableWords.splice(index, 1)[0]; 
            };

            if (chosenStructure > 0 && Math.random() < 0.05) {
                trackWords.push(Math.random() < 0.7 ? 'The' : 'No');
            }

            if (chosenStructure === 0) {
                trackWords.push(capitalize(pullWord()));
            } else if (chosenStructure === 1) {
                trackWords.push(capitalize(pullWord()));
                trackWords.push(capitalize(pullWord()));
            } else if (chosenStructure === 2) {
                trackWords.push(capitalize(pullWord()));
                trackWords.push(capitalize(pullWord()));
                trackWords.push(capitalize(pullWord()));
            }

            const oldNameWithoutExt = file.name.replace(/\.[^/.]+$/, "");
            let baseGeneratedName = trackWords.join(' ');
            
            // Layout customization depending on checkbox state
            let finalTrackName = keepOriginalName 
                ? `${baseGeneratedName} (${oldNameWithoutExt}).mp3` 
                : `${baseGeneratedName}.mp3`;

            let duplicateCounter = 1;
            while (usedFullNames.has(finalTrackName)) {
                finalTrackName = keepOriginalName 
                    ? `${baseGeneratedName} ${duplicateCounter} (${oldNameWithoutExt}).mp3`
                    : `${baseGeneratedName} ${duplicateCounter}.mp3`;
                duplicateCounter++;
            }
            usedFullNames.add(finalTrackName);

            zip.file(finalTrackName, file);
        }

        statusDiv.innerText = "Finalizing your ZIP package...";

        zip.generateAsync({ type: "blob" }).then(function (content) {
            generatedZipBlob = content;
            statusDiv.style.color = "#81c784";
            statusDiv.innerText = "All tracks processed uniquely!";
            
            processBtn.style.display = "none";
            downloadBtn.style.display = "block";
            resetLink.style.display = "inline-block";
        }).catch(err => {
            statusDiv.innerText = "Error packing zip.";
            console.error(err);
            processBtn.disabled = false;
        });
    });

    downloadBtn.addEventListener('click', () => {
        if (!generatedZipBlob) return;
        const element = document.createElement('a');
        element.href = URL.createObjectURL(generatedZipBlob);
        element.download = `${selectedGenre}_named_playlist.zip`;
        document.body.appendChild(element);
        element.click();
        document.body.removeChild(element);
    });

    resetLink.addEventListener('click', () => {
        generatedZipBlob = null;
        fileInput.disabled = false;
        keepOldNameCheckbox.disabled = false;
        fileInput.value = "";
        processBtn.disabled = true;
        processBtn.style.display = "block";
        downloadBtn.style.display = "none";
        resetLink.style.display = "none";
        statusDiv.style.color = "#b39ddb";
        statusDiv.innerText = "Cleared. Ready for another stack.";
    });
</script>

